# 画像生成は Codex app-server stdio + GPT Image 2 のみを使います。
# OpenAI APIキーや画像生成APIエンドポイントは設定しません。
CODEX_APP_SERVER_BIN=codex
CODEX_APP_SERVER_AGENT_MODEL=gpt-5.5
CODEX_APP_SERVER_TIMEOUT_MS=720000
LP_VERCEL_COMMAND=npx vercel --prod --yes
# 公開中LP確認・比較ボタン用。Vercelの公開URLを入れる。
# LP_PUBLIC_URL=https://your-project.vercel.app/

# UTAGE API（UTAGE管理画面 > API設定 から発行）
UTAGE_API_KEY=
UTAGE_API_BASE_URL=https://api.utage-system.com/v1
