hYBREdECed.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <picture class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/eNnUh289qxOA.jpg\">\n        <img class=\"lp-section-img img-ratio-reasons\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/3r1kGny3YC70.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <picture class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/d0SQ4bxf7pfy.jpg\">\n        <img class=\"lp-section-img img-ratio-why\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/h0q93sgwqddO.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <picture id=\"features\" class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/TTzWioaKTnpA.jpg\">\n        <img class=\"lp-section-img img-ratio-features1\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/PoeimdOpp6iL.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <picture class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/mfAdEVahaVzZ.jpg\">\n        <img class=\"lp-section-img img-ratio-features2\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/PfUZFzbinBrC.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <div class=\"lp-section-wrap reveal\">\n        <picture class=\"lp-section\">\n          <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/d2ijUau9n0YX.jpg\">\n          <img class=\"lp-section-img img-ratio-compare\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/ZTRJL3K4otKd.jpg\" alt=\"\" loading=\"lazy\">\n        </picture>\n        <a class=\"lp-cta lp-cta-compare\" data-cta=\"document\" href=\"#\" aria-label=\"資料をダウンロードする\"></a>\n      </div>\n      <picture id=\"curriculum\" class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/dbbc4OVTwDnI.jpg\">\n        <img class=\"lp-section-img img-ratio-curriculum\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/Z7LTdIeuNBnU.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <picture id=\"instructors\" class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/jA4b5cHG4oPZ.jpg\">\n        <img class=\"lp-section-img img-ratio-instructors\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/v1ZRI6MxwwPE.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <picture id=\"flow\" class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/ajRBBovCG5Pj.jpg\">\n        <img class=\"lp-section-img img-ratio-flow\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/v6iAT5Haa04u.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <picture id=\"faq\" class=\"lp-section reveal\">\n        <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/o4tLCLamcjqt.jpg\">\n        <img class=\"lp-section-img img-ratio-faq-header\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/LZP29tHFhcRc.jpg\" alt=\"\" loading=\"lazy\">\n      </picture>\n      <div class=\"faq-accordion reveal\">\n        <div class=\"faq-item\">\n          <button type=\"button\" class=\"faq-question\" aria-expanded=\"false\">\n            <span class=\"faq-q-badge\">Q</span>\n            <span class=\"faq-q-text\">学習開始までに準備しなければいけないことを教えてください。</span>\n            <span class=\"faq-chevron\" aria-hidden=\"true\"></span>\n          </button>\n          <div class=\"faq-answer\">\n            <div class=\"faq-answer-inner\">\n              <div class=\"faq-answer-content\">\n              <span class=\"faq-a-badge\">A</span>\n              <p>特別な事前学習は不要です。パソコンとインターネット環境があれば、開講日からすぐに受講を始めていただけます。オンライン面談時に学習の進め方も個別にご案内します。</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"faq-item\">\n          <button type=\"button\" class=\"faq-question\" aria-expanded=\"false\">\n            <span class=\"faq-q-badge\">Q</span>\n            <span class=\"faq-q-text\">本業が忙しいのですが、大丈夫ですか？どのくらいの稼働確保が必要ですか？</span>\n            <span class=\"faq-chevron\" aria-hidden=\"true\"></span>\n          </button>\n          <div class=\"faq-answer\">\n            <div class=\"faq-answer-inner\">\n              <div class=\"faq-answer-content\">\n              <span class=\"faq-a-badge\">A</span>\n              <p>平均的な学習時間は週3〜5時間を目安にしています。講義はオンデマンド動画中心で、ご自身のペースで視聴・演習を進められるため、本業と両立しながら受講されている方がほとんどです。</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"faq-item\">\n          <button type=\"button\" class=\"faq-question\" aria-expanded=\"false\">\n            <span class=\"faq-q-badge\">Q</span>\n            <span class=\"faq-q-text\">未経験ですがカリキュラムについていけますか？コンサルは完全未経験で、自信がないのですが大丈夫でしょうか？</span>\n            <span class=\"faq-chevron\" aria-hidden=\"true\"></span>\n          </button>\n          <div class=\"faq-answer\">\n            <div class=\"faq-answer-inner\">\n              <div class=\"faq-answer-content\">\n              <span class=\"faq-a-badge\">A</span>\n              <p>カリキュラムは経営知識の基礎から順を追って学べる構成になっており、コンサル未経験の方を主な対象としています。担当メンターが学習の進捗に合わせて個別にサポートしますので、安心して取り組んでいただけます。</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"faq-item\">\n          <button type=\"button\" class=\"faq-question\" aria-expanded=\"false\">\n            <span class=\"faq-q-badge\">Q</span>\n            <span class=\"faq-q-text\">支払い方法と支払いタイミングはいつでしょうか？</span>\n            <span class=\"faq-chevron\" aria-hidden=\"true\"></span>\n          </button>\n          <div class=\"faq-answer\">\n            <div class=\"faq-answer-inner\">\n              <div class=\"faq-answer-content\">\n              <span class=\"faq-a-badge\">A</span>\n              <p>お支払いはクレジットカードまたは銀行振込に対応しています。タイミングは合格発表後、受講開始前のお手続きとなります。詳しい金額・分割払いの可否は無料相談時にご案内します。</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"faq-item\">\n          <button type=\"button\" class=\"faq-question\" aria-expanded=\"false\">\n            <span class=\"faq-q-badge\">Q</span>\n            <span class=\"faq-q-text\">途中で解約の場合、返金はされますか？</span>\n            <span class=\"faq-chevron\" aria-hidden=\"true\"></span>\n          </button>\n          <div class=\"faq-answer\">\n            <div class=\"faq-answer-inner\">\n              <div class=\"faq-answer-content\">\n              <span class=\"faq-a-badge\">A</span>\n              <p>受講開始前の解約は所定の期日までにご連絡いただければ返金対応いたします。受講開始後の返金可否については利用規約に定める条件をご確認ください。</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"faq-item\">\n          <button type=\"button\" class=\"faq-question\" aria-expanded=\"false\">\n            <span class=\"faq-q-badge\">Q</span>\n            <span class=\"faq-q-text\">子育てや家事をしながら学習は可能ですか？</span>\n            <span class=\"faq-chevron\" aria-hidden=\"true\"></span>\n          </button>\n          <div class=\"faq-answer\">\n            <div class=\"faq-answer-inner\">\n              <div class=\"faq-answer-content\">\n              <span class=\"faq-a-badge\">A</span>\n              <p>はい、オンデマンド形式の講義が中心のため、すきま時間を使って学習を進めていただけます。実際に子育てや家事と両立しながら受講されている方も多くいらっしゃいます。</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div class=\"lp-section-wrap reveal\">\n        <picture class=\"lp-section\">\n          <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/MgmPmjWXE8cp.jpg\">\n          <img class=\"lp-section-img img-ratio-faq-footer\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/gtj1e6rve8qf.jpg\" alt=\"\" loading=\"lazy\">\n        </picture>\n        <a class=\"lp-cta lp-cta-faq\" data-cta=\"line\" href=\"#\" aria-label=\"公式LINEで無料相談\"></a>\n      </div>\n    </main>\n    <button type=\"button\" class=\"back-to-top\" aria-label=\"トップへ戻る\">↑</button>\n    <script>\n// TODO: 実際のリンク先が決まったら、ここを書き換えるだけで全CTAボタンに反映されます\nconst CTA_LINKS = {\n  line: \"#\", // 公式LINE無料相談の遷移先\n  document: \"#\", // 資料ダウンロードの遷移先\n};\n\ndocument.querySelectorAll(\"[data-cta]\").forEach((el) => {\n  const url = CTA_LINKS[el.dataset.cta];\n  if (url && url !== \"#\") {\n    el.href = url;\n    el.target = \"_blank\";\n    el.rel = \"noopener noreferrer\";\n  } else {\n    el.addEventListener(\"click\", (e) => e.preventDefault());\n  }\n});\n\n// クリックリップルエフェクト（Neonアニメーション: ripple-click-effect）\ndocument.querySelectorAll(\".lp-cta\").forEach((button) => {\n  button.addEventListener(\"click\", (e) => {\n    const rect = button.getBoundingClientRect();\n    const circle = document.createElement(\"span\");\n    const size = Math.max(rect.width, rect.height);\n    circle.className = \"lp-cta-ripple\";\n    circle.style.width = circle.style.height = `${size}px`;\n    circle.style.left = `${e.clientX - rect.left - size / 2}px`;\n    circle.style.top = `${e.clientY - rect.top - size / 2}px`;\n    button.appendChild(circle);\n    circle.addEventListener(\"animationend\", () => circle.remove());\n  });\n});\n\nconst observer = new IntersectionObserver((entries) => {\n  entries.forEach((entry) => {\n    if (entry.isIntersecting) {\n      entry.target.classList.add(\"is-visible\");\n      observer.unobserve(entry.target);\n    }\n  });\n}, { threshold: 0.2 });\n\ndocument.querySelectorAll(\".reveal\").forEach((el) => observer.observe(el));\n\nconst backToTopBtn = document.querySelector(\".back-to-top\");\nwindow.addEventListener(\"scroll\", () => {\n  backToTopBtn.classList.toggle(\"is-visible\", window.scrollY > 400);\n});\nbackToTopBtn.addEventListener(\"click\", () => window.scrollTo({ top: 0, behavior: \"smooth\" }));\n\n// FAQアコーディオン\ndocument.querySelectorAll(\".faq-question\").forEach((btn) => {\n  btn.addEventListener(\"click\", () => {\n    const item = btn.closest(\".faq-item\");\n    const isOpen = btn.getAttribute(\"aria-expanded\") === \"true\";\n    btn.setAttribute(\"aria-expanded\", String(!isOpen));\n    item.classList.toggle(\"is-open\", !isOpen);\n  });\n});\n\n// スクロール進行バー（Neonアニメーション: scroll-progress-bar）\nconst scrollProgressBar = document.querySelector(\".scroll-progress\");\nfunction updateScrollProgress() {\n  const scrollTop = document.documentElement.scrollTop;\n  const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;\n  scrollProgressBar.style.width = `${(scrollTop / scrollHeight) * 100}%`;\n}\nwindow.addEventListener(\"scroll\", updateScrollProgress);\n\n    </script>\n  </body>\n</html>",
