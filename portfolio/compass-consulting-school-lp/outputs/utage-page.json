    "html_source": "<!doctype html>\n<html lang=\"ja\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>COMPASS 超実践型コンサルタント養成スクール LP</title>\n    <style>\nhtml,\nbody {\n  margin: 0;\n  min-height: 100%;\n  background: #eef4fb;\n}\n\nbody {\n  font-family: -apple-system, BlinkMacSystemFont, \"Hiragino Sans\", \"Yu Gothic\", sans-serif;\n}\n\n.lp-shell {\n  max-width: 1200px;\n  margin: 0 auto;\n  width: 100%;\n  background: #fff;\n  box-shadow: 0 0 36px rgba(20, 60, 120, 0.12);\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n\n.lp-section {\n  display: block;\n}\n\n.lp-section-img {\n  display: block;\n  width: 100%;\n  height: auto;\n}\n\n/* スクロールで下から表示(Neonアニメーション: scroll-fade-up + title-fade-up-blurのぼかしを合成) */\n.reveal {\n  opacity: 0;\n  transform: translateY(32px);\n  filter: blur(6px);\n  transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1), filter 0.9s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.reveal.is-visible {\n  opacity: 1;\n  transform: translateY(0);\n  filter: blur(0);\n}\n\n.lp-section-hero {\n  opacity: 0;\n  animation: hero-fade-in 1s ease forwards;\n}\n\n@keyframes hero-fade-in {\n  from {\n    opacity: 0;\n    transform: scale(1.02);\n  }\n  to {\n    opacity: 1;\n    transform: scale(1);\n  }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .reveal,\n  .lp-section-hero {\n    opacity: 1;\n    transform: none;\n    filter: none;\n    animation: none;\n    transition: none;\n  }\n}\n\n/* 画像読み込み前にレイアウトの高さを確保（実測値） */\n.img-ratio-hero { aspect-ratio: 1536 / 1024; }\n.img-ratio-campaign { aspect-ratio: 1717 / 916; }\n.img-ratio-problem { aspect-ratio: 1536 / 1024; }\n.img-ratio-target { aspect-ratio: 1697 / 927; }\n.img-ratio-about { aspect-ratio: 1717 / 916; }\n.img-ratio-reasons { aspect-ratio: 1717 / 916; }\n.img-ratio-why { aspect-ratio: 1717 / 916; }\n.img-ratio-features1 { aspect-ratio: 1717 / 916; }\n.img-ratio-features2 { aspect-ratio: 1536 / 1024; }\n.img-ratio-compare { aspect-ratio: 1717 / 916; }\n.img-ratio-curriculum { aspect-ratio: 1717 / 916; }\n.img-ratio-instructors { aspect-ratio: 1717 / 916; }\n.img-ratio-flow { aspect-ratio: 1536 / 1024; }\n.img-ratio-faq-header { aspect-ratio: 1536 / 200; }\n.img-ratio-faq-footer { aspect-ratio: 1536 / 454; }\n\n@media (max-width: 767px) {\n  .img-ratio-hero { aspect-ratio: 1536 / 1024; }\n  .img-ratio-campaign { aspect-ratio: 1672 / 941; }\n  .img-ratio-problem { aspect-ratio: 1536 / 1024; }\n  .img-ratio-target { aspect-ratio: 1536 / 1024; }\n  .img-ratio-about { aspect-ratio: 1536 / 1024; }\n  .img-ratio-reasons { aspect-ratio: 1536 / 1024; }\n  .img-ratio-why { aspect-ratio: 1536 / 1024; }\n  .img-ratio-features1 { aspect-ratio: 1536 / 1024; }\n  .img-ratio-features2 { aspect-ratio: 1536 / 1024; }\n  .img-ratio-compare { aspect-ratio: 1536 / 1024; }\n  .img-ratio-curriculum { aspect-ratio: 1536 / 1024; }\n  .img-ratio-instructors { aspect-ratio: 1536 / 1024; }\n  .img-ratio-flow { aspect-ratio: 864 / 1821; }\n  .img-ratio-faq-header { aspect-ratio: 1536 / 198; }\n  .img-ratio-faq-footer { aspect-ratio: 1536 / 434; }\n}\n\n/* CTAボタン（画像に重ねる実クリック領域） */\n.lp-section-wrap {\n  position: relative;\n  display: block;\n}\n\n.lp-cta {\n  position: absolute;\n  display: block;\n  overflow: hidden;\n  border-radius: 16px;\n  cursor: pointer;\n  -webkit-tap-highlight-color: transparent;\n  outline-offset: 4px;\n  transition: transform 0.2s ease, filter 0.2s ease;\n}\n\n.lp-cta:hover,\n.lp-cta:focus-visible {\n  transform: scale(1.03);\n  filter: brightness(1.06);\n}\n\n.lp-cta:active {\n  transform: scale(0.98);\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .lp-cta {\n    transition: none;\n  }\n  .lp-cta:hover,\n  .lp-cta:focus-visible,\n  .lp-cta:active {\n    transform: none;\n  }\n}\n\n/* クリックリップルエフェクト（Neonアニメーション: ripple-click-effect） */\n.lp-cta-ripple {\n  position: absolute;\n  border-radius: 50%;\n  background: rgba(255, 255, 255, 0.65);\n  transform: scale(0);\n  animation: lpCtaRipple 0.6s ease-out;\n  pointer-events: none;\n}\n\n@keyframes lpCtaRipple {\n  to {\n    transform: scale(4);\n    opacity: 0;\n  }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .lp-cta-ripple {\n    animation: none;\n    display: none;\n  }\n}\n\n/* ホバー光沢スイープ（Neonアニメーション: button-shine-sweep） */\n.lp-cta::before {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  left: -75%;\n  width: 50%;\n  height: 100%;\n  background: linear-gradient(120deg, transparent, rgba(255, 255, 255, 0.55), transparent);\n  transform: skewX(-20deg);\n  transition: left 0.6s ease;\n  pointer-events: none;\n}\n\n.lp-cta:hover::before,\n.lp-cta:focus-visible::before {\n  left: 125%;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .lp-cta::before {\n    transition: none;\n    display: none;\n  }\n}\n\n/* CTAボタンの脈動（Neonアニメーション: pulse-cta、最重要CTAのみ） */\n.lp-cta-pulse {\n  animation: lpCtaPulse 2.2s ease-in-out infinite;\n}\n\n@keyframes lpCtaPulse {\n  0%, 100% {\n    box-shadow: 0 0 0 0 rgba(30, 95, 214, 0.45);\n  }\n  50% {\n    box-shadow: 0 0 0 12px rgba(30, 95, 214, 0);\n  }\n}\n\n.lp-cta-pulse:hover,\n.lp-cta-pulse:focus-visible {\n  animation-play-state: paused;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .lp-cta-pulse {\n    animation: none;\n  }\n}\n\n/* スクロール進行バー（Neonアニメーション: scroll-progress-bar） */\n.scroll-progress {\n  position: fixed;\n  top: 0;\n  left: 0;\n  height: 3px;\n  width: 0%;\n  background: #1e5fd6;\n  z-index: 9999;\n  transition: width 0.1s ease-out;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .scroll-progress {\n    transition: none;\n  }\n}\n\n.lp-cta-hero-nav { left: 43.3%; top: 11.3%; width: 15.1%; height: 8.3%; }\n.lp-cta-hero-main { left: 2.1%; top: 82.3%; width: 48.7%; height: 9.3%; }\n.lp-cta-campaign { left: 72.3%; top: 51.9%; width: 21.4%; height: 15.2%; }\n.lp-cta-compare { left: 72.3%; top: 78.5%; width: 23.3%; height: 9.1%; border-radius: 999px; }\n.lp-cta-faq { left: 55.08%; top: 37.89%; width: 31.38%; height: 19.82%; }\n\n@media (max-width: 767px) {\n  .lp-cta-hero-nav { left: 82.6%; top: 2.4%; width: 16.9%; height: 6.9%; }\n  .lp-cta-hero-main { left: 21.9%; top: 82.4%; width: 57.3%; height: 9.8%; }\n  .lp-cta-campaign { left: 56.3%; top: 63.7%; width: 32%; height: 15.2%; }\n  .lp-cta-compare { left: 28.7%; top: 89.7%; width: 42.3%; height: 7.8%; }\n  .lp-cta-faq { left: 56.58%; top: 36.41%; width: 27.28%; height: 20.74%; }\n}\n\n/* ナビゲーションメニューのアンカーリンク（下線が伸びる強調: Neonアニメーション underline-grow を応用） */\n.lp-nav-link {\n  position: absolute;\n  display: block;\n  cursor: pointer;\n  -webkit-tap-highlight-color: transparent;\n  outline-offset: 3px;\n}\n\n.lp-nav-link::after {\n  content: \"\";\n  position: absolute;\n  left: 0;\n  bottom: -2px;\n  width: 100%;\n  height: 2px;\n  background: #1e5fd6;\n  transform: scaleX(0);\n  transform-origin: left;\n  transition: transform 0.3s ease;\n}\n\n.lp-nav-link:hover::after,\n.lp-nav-link:focus-visible::after {\n  transform: scaleX(1);\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .lp-nav-link::after {\n    transition: none;\n  }\n}\n\n.lp-nav-link-about { left: 2.6%; top: 12.7%; width: 10.09%; height: 5.86%; }\n.lp-nav-link-features { left: 12.7%; top: 12.7%; width: 3.91%; height: 5.86%; }\n.lp-nav-link-curriculum { left: 16.6%; top: 12.7%; width: 7.16%; height: 5.86%; }\n.lp-nav-link-instructors { left: 23.76%; top: 12.7%; width: 5.6%; height: 5.86%; }\n.lp-nav-link-flow { left: 29.36%; top: 12.7%; width: 5.66%; height: 5.86%; }\n.lp-nav-link-faq { left: 35.03%; top: 12.7%; width: 5.99%; height: 5.86%; }\n\n@media (max-width: 767px) {\n  .lp-nav-link-about { left: 24.09%; top: 3.42%; width: 12.53%; height: 3.91%; }\n  .lp-nav-link-features { left: 36.62%; top: 3.42%; width: 8.5%; height: 3.91%; }\n  .lp-nav-link-curriculum { left: 45.12%; top: 3.42%; width: 9.64%; height: 3.91%; }\n  .lp-nav-link-instructors { left: 54.75%; top: 3.42%; width: 9.86%; height: 3.91%; }\n  .lp-nav-link-flow { left: 64.62%; top: 3.42%; width: 8.53%; height: 3.91%; }\n  .lp-nav-link-faq { left: 73.14%; top: 3.42%; width: 8.14%; height: 3.91%; }\n}\n\n/* FAQアコーディオン(実HTML) */\n.faq-accordion {\n  display: grid;\n  grid-template-columns: 1fr;\n  align-items: start;\n  gap: 16px;\n  background: #fff;\n  padding: 8px 4% 32px;\n}\n\n@media (min-width: 768px) {\n  .faq-accordion {\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    padding: 8px 4.2% 40px;\n  }\n}\n\n.faq-item {\n  border: 1px solid #e3ecf9;\n  border-radius: 16px;\n  background: #fff;\n  box-shadow: 0 6px 18px rgba(20, 60, 120, 0.06);\n  overflow: hidden;\n}\n\n.faq-question {\n  width: 100%;\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  padding: 18px 20px;\n  border: none;\n  background: none;\n  cursor: pointer;\n  text-align: left;\n  font-family: inherit;\n  -webkit-tap-highlight-color: transparent;\n}\n\n.faq-q-badge,\n.faq-a-badge {\n  flex-shrink: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 30px;\n  height: 30px;\n  border-radius: 50%;\n  background: #1e5fd6;\n  color: #fff;\n  font-weight: 700;\n  font-size: 0.85rem;\n}\n\n.faq-a-badge {\n  background: #6fa3e8;\n}\n\n.faq-q-text {\n  flex: 1;\n  font-weight: 700;\n  font-size: 0.95rem;\n  color: #16233f;\n  line-height: 1.5;\n}\n\n.faq-chevron {\n  flex-shrink: 0;\n  width: 12px;\n  height: 12px;\n  border-right: 2px solid #1e5fd6;\n  border-bottom: 2px solid #1e5fd6;\n  transform: rotate(45deg);\n  transition: transform 0.3s ease;\n  margin-top: -4px;\n}\n\n.faq-item.is-open .faq-chevron {\n  transform: rotate(225deg);\n  margin-top: 4px;\n}\n\n.faq-answer {\n  display: grid;\n  grid-template-rows: 0fr;\n  transition: grid-template-rows 0.35s ease;\n}\n\n.faq-item.is-open .faq-answer {\n  grid-template-rows: 1fr;\n}\n\n.faq-answer-inner {\n  overflow: hidden;\n}\n\n.faq-answer-content {\n  display: flex;\n  gap: 14px;\n  padding: 0 20px 20px 20px;\n}\n\n.faq-answer p {\n  margin: 0;\n  font-size: 0.9rem;\n  line-height: 1.8;\n  color: #445070;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .faq-chevron,\n  .faq-answer {\n    transition: none;\n  }\n}\n\n/* トップへ戻るボタン */\n.back-to-top {\n  position: fixed;\n  right: 24px;\n  bottom: 24px;\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  border: none;\n  background: #1a1a1a;\n  color: #fff;\n  font-size: 1.1rem;\n  cursor: pointer;\n  opacity: 0;\n  visibility: hidden;\n  transform: translateY(16px);\n  transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s;\n  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.3);\n  z-index: 20;\n}\n\n.back-to-top.is-visible {\n  opacity: 1;\n  visibility: visible;\n  transform: translateY(0);\n}\n\n.back-to-top:hover {\n  background: #1e5fd6;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .back-to-top {\n    transition: opacity 0.15s linear, visibility 0.15s linear;\n    transform: none;\n  }\n}\n\n    </style>\n  </head>\n  <body>\n    <div class=\"scroll-progress\"></div>\n    <main class=\"lp-shell\" aria-label=\"COMPASS 超実践型コンサルタント養成スクール LP\">\n      <div class=\"lp-section-wrap\">\n        <picture class=\"lp-section lp-section-hero\">\n          <source media=\"(max-width: 767px)\" srcset=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/m6fpKJjm5BcB.jpg\">\n          <img class=\"lp-section-img img-ratio-hero\" src=\"https://utagesystem.s3.ap-northeast-1.wasabisys.com/WfuPRx4FsHxu/NqtlHKUS075H.jpg\" alt=\"COMPASS 超実践型コンサルタント養成スクール LP\" decoding=\"async\" fetchpriority=\"high\">\n        </picture>\n        <a class=\"lp-cta lp-cta-hero-nav\" data-cta=\"line\" href=\"#\" aria-label=\"無料相談はこちら\"></a>\n        <a class=\"lp-cta lp-cta-hero-main lp-cta-pulse\" data-cta=\"line\" href=\"#\" aria-label=\"無料相談はこちら\"></a>\n        <a class=\"lp-nav-link lp-nav-link-about\" href=\"#about\" aria-label=\"COMPASSについて\"></a>\n        <a class=\"lp-nav-link lp-nav-link-features\" href=\"#features\" aria-label=\"特徴\"></a>\n        <a class=\"lp-nav-link